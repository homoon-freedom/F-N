function initDynamicData() {
    const savedNeeds = localStorage.getItem('custom_needs_data');
    const savedEmotions = localStorage.getItem('custom_emotions_data');
    
    currentNeedsData = savedNeeds ? JSON.parse(savedNeeds) : [...needsData];
    currentEmotionsData = savedEmotions ? JSON.parse(savedEmotions) : [...emotionsData];
